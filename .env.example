# =============================================================================
# CA ATTENDANCE MANAGER — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in every value before running the app.
# NEVER commit .env.local to Git.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE — Public (safe to expose to the browser)
# Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# -----------------------------------------------------------------------------
# SUPABASE — Server-only (NEVER prefix with NEXT_PUBLIC_)
# Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# These two are aliases used by the Supabase CLI for local development.
# Set them to the same values as the NEXT_PUBLIC_ versions above.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# Get these from: Google Cloud Console → APIs & Services → Credentials
# Steps: Create OAuth 2.0 Client ID → Web application
# Authorised redirect URI: https://your-project-ref.supabase.co/auth/v1/callback
# For local dev also add:  http://localhost:54321/auth/v1/callback
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret


# -----------------------------------------------------------------------------
# APP URL
# Local dev: http://localhost:3000
# Production: your Netlify domain, e.g. https://ca-attendance.netlify.app
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# CRON SECRET
# Protects the /api/cron/inactivity-check endpoint from unauthorized calls.
# Generate a strong random string, e.g.: openssl rand -hex 32
# Set the same value in your Netlify environment variables.
# -----------------------------------------------------------------------------
CRON_SECRET=replace-with-a-strong-random-string-min-32-chars
